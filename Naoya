-----------------------------------------------------------
-- TRUE GHOST CLONE LOGIC
-----------------------------------------------------------
local function spawnAvatarClone(cframe, activeColor)
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    char.Archivable = true
    local clone = char:Clone()
    char.Archivable = false
    
    clone:SetPrimaryPartCFrame(cframe)
    clone.Parent = workspace
    
    local cloneHum = clone:FindFirstChildOfClass("Humanoid")
    if cloneHum then cloneHum:Destroy() end
    local cloneHrp = clone:FindFirstChild("HumanoidRootPart")
    if cloneHrp then cloneHrp:Destroy() end

    for _, obj in pairs(clone:GetDescendants()) do
        if obj:IsA("BasePart") then
            obj.CanCollide, obj.CanTouch, obj.CanQuery = false, false, false
            obj.Anchored = true
            obj.Material = Enum.Material.ForceField
            obj.Color = activeColor
            obj.CastShadow = false
        elseif obj:IsA("LocalScript") or obj:IsA("Script") or obj:IsA("Sound") or obj:IsA("Decal") then
            obj:Destroy()
        end
    end
    
    task.spawn(function()
        for i = 1, 15 do
            for _, p in pairs(clone:GetDescendants()) do
                if p:IsA("BasePart") then p.Transparency = (i/15) + 0.2 end
            end
            task.wait(0.03)
        end
        clone:Destroy()
    end)
end

