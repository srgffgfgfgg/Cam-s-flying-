-----------------------------------------------------------
-- MAIN LOOP
-----------------------------------------------------------
local hue = 0
RunService.RenderStepped:Connect(function()
    hue = (hue + 0.01) % 1
    local rainbowColor = Color3.fromHSV(hue, 0.8, 0.8)
    
    if rainbowEnabled then
        local dark = Color3.fromHSV(hue, 0.8, 0.3)
        MainFrame.BackgroundColor3, SettingsFrame.BackgroundColor3, MenuToggle.BackgroundColor3 = dark, dark, dark
        local btns = {Title, BindButton, CamModeBtn, BeforeImageBtn, AfterImageBtn, SpeedBtn, SpeedModeBtn, RainbowBtn}
        for _, b in pairs(btns) do b.BackgroundColor3 = rainbowColor end
    end

    if not player.Character or not player.Character:FindFirstChild("Humanoid") then return end
    local hum, root = player.Character.Humanoid, player.Character.HumanoidRootPart

    -- Speed
    if speedEnabled then
        if speedMode == "Static" then hum.WalkSpeed = 100
        elseif speedMode == "Overtime" and hum.MoveDirection.Magnitude > 0 then
            currentRampSpeed = math.min(currentRampSpeed + 0.4, 150)
            hum.WalkSpeed = currentRampSpeed
        else currentRampSpeed = 16 hum.WalkSpeed = 16 end
    end

    -- Dual Images
    if root.Velocity.Magnitude > 5 then
        if beforeImagesEnabled then
            spawnClone(root.CFrame + (root.Velocity * 0.25), rainbowColor) -- Closer Before-Image
        end
        if afterImagesEnabled then
            spawnClone(root.CFrame, rainbowColor) -- Standard After-Image
        end
    end

    -- Combat
    if isLocked and targetPart and targetPart.Parent and targetPart.Parent:FindFirstChild("HumanoidRootPart") then
        root.CFrame = CFrame.lookAt(root.Position, Vector3.new(targetPart.Position.X, root.Position.Y, targetPart.Position.Z))
        hum.AutoRotate = false
        if cameraMode == "Lock-On" then camera.CFrame = CFrame.lookAt(camera.CFrame.Position, targetPart.Position) end
    else
        isLocked, targetPart, hum.AutoRotate = false, nil, true
        StatusLabel.Text = "STATUS: IDLE"
    end
end)

-- Standard Bind Logic
BindButton.MouseButton1Click:Connect(function() isBinding = true BindButton.Text = "...PRESS KEY..." end)
UserInputService.InputBegan:Connect(function(i, p)
    if isBinding then lockKey, isBinding, BindButton.Text = i.KeyCode ~= Enum.KeyCode.Unknown and i.KeyCode or i.UserInputType, false, "BIND: " .. tostring(i.KeyCode.Name):gsub("Button","") return end
    if p then return end
    if i.KeyCode == lockKey or i.UserInputType == lockKey then
        isLocked = not isLocked
        StatusLabel.Text = isLocked and "STATUS: LOCKED" or "STATUS: IDLE"
        if isLocked then 
            local target, dist = nil, maxDistance
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (root.Position - v.Character.HumanoidRootPart.Position).Magnitude
                    if d < dist then target, dist = v.Character.HumanoidRootPart, d end
                end
            end
            targetPart = target
            if not targetPart then isLocked = false end
        end
    end
end)
