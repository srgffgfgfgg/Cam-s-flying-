-----------------------------------------------------------
-- CLONE GENERATOR
-----------------------------------------------------------
local function spawnClone(cframe, rainbowColor)
    if not player.Character then return end
    player.Character.Archivable = true
    local clone = player.Character:Clone()
    for _, obj in pairs(clone:GetDescendants()) do
        if obj:IsA("BasePart") then
            obj.CanCollide, obj.Anchored, obj.Material = false, true, Enum.Material.ForceField
            obj.Color = rainbowColor
        elseif not (obj:IsA("SpecialMesh") or obj:IsA("CharacterMesh")) then obj:Destroy() end
    end
    clone:SetPrimaryPartCFrame(cframe)
    clone.Parent = workspace
    task.delay(0.35, function()
        for i = 1, 10 do
            for _, p in pairs(clone:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = i/10 end end
            task.wait(0.04)
        end
        clone:Destroy()
    end)
end

