MenuToggle.Activated:Connect(function() MainFrame.Visible = not MainFrame.Visible end)

AntiLagBtn.Activated:Connect(function()
    AntiLagBtn.Text = "Anti-Lag: ACTIVATED"
    game.Lighting.GlobalShadows = false
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
        elseif v:IsA("Texture") or v:IsA("Decal") then
            if v.Name ~= "face" then v:Destroy() end -- Keeps avatars' faces intact
        end
    end
end)

DestroyGuiBtn.Activated:Connect(function()
    ScreenGui:Destroy() -- Removes the GUI completely, but the loop keeps running!
end)

BindButton.Activated:Connect(function() isBinding = true BindButton.Text = "...PRESS KEY..." end)

UserInputService.InputBegan:Connect(function(input, processed)
    if isBinding then
        local key = (input.KeyCode ~= Enum.KeyCode.Unknown) and input.KeyCode or input.UserInputType
        lockKey, isBinding = key, false
        if ScreenGui.Parent then BindButton.Text = "BIND: " .. tostring(key.Name):gsub("Button",""):gsub("MouseButton","MB") end
        return
    end
    if processed then return end
    if input.KeyCode == lockKey or input.UserInputType == lockKey then
        isLocked = not isLocked
        if isLocked then
            local closestTarget, dist = nil, maxDistance
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (player.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
                    if d < dist then closestTarget, dist = v.Character.HumanoidRootPart, d end
                end
            end
            targetPart = closestTarget
            if ScreenGui.Parent then StatusLabel.Text = targetPart and "STATUS: LOCKED" or "STATUS: NO TARGET" end
            if not targetPart then isLocked = false end
        else
            if ScreenGui.Parent then StatusLabel.Text = "STATUS: IDLE" end
        end
    end
end)

-----------------------------------------------------------
-- RUNTIME
-----------------------------------------------------------
local hue = 0
RunService.RenderStepped:Connect(function()
    hue = (hue + 0.01) % 1
    local isRainbow = (colorPresets[colorIndex].Name == "Rainbow")
    local activeColor = isRainbow and Color3.fromHSV(hue, 0.8, 0.8) or colorPresets[colorIndex].Color
    local dark = isRainbow and Color3.fromHSV(hue, 0.8, 0.2) or Color3.fromRGB(20, 20, 20)

    -- Only color cycle the UI if it hasn't been destroyed
    if ScreenGui.Parent then
        MainFrame.BackgroundColor3, SettingsFrame.BackgroundColor3, MenuToggle.BackgroundColor3 = dark, dark, dark
        local btns = {Title, BindButton, CamModeBtn, ColorSelectBtn, BeforeImageBtn, AfterImageBtn, SpeedBtn, SpeedModeBtn, AntiLagBtn, DestroyGuiBtn}
        for _, b in pairs(btns) do 
            b.BackgroundColor3 = activeColor 
            b.TextColor3 = (isRainbow or colorPresets[colorIndex].Name == "White") and Color3.new(0,0,0) or Color3.new(1,1,1)
        end
    end

    if not player.Character or not player.Character:FindFirstChild("Humanoid") then return end
    local hum, root = player.Character.Humanoid, player.Character.HumanoidRootPart

    -- Speed
    if speedEnabled then
        if speedMode == "Static" then hum.WalkSpeed = 100
        elseif speedMode == "Overtime" and hum.MoveDirection.Magnitude > 0 then
            currentRampSpeed = math.min((currentRampSpeed or 16) + 0.4, 150)
            hum.WalkSpeed = currentRampSpeed
        else currentRampSpeed = 16 hum.WalkSpeed = 90 end
    end

    -- Spawning Logic
    if root.Velocity.Magnitude > 5 then
        if beforeImagesEnabled then spawnAvatarClone(root.CFrame * CFrame.new(0,0,-4), activeColor) end
        if afterImagesEnabled then spawnAvatarClone(root.CFrame * CFrame.new(0,0,1), activeColor) end
    end

    -- Combat Lock
    if isLocked and targetPart and targetPart.Parent and targetPart.Parent:FindFirstChild("Humanoid") then
        targetHighlight.Adornee = targetPart.Parent
        targetHighlight.FillColor, targetHighlight.OutlineColor = activeColor, activeColor
        targetHighlight.Enabled, targetHighlight.Parent = true, CoreGui
        root.CFrame = CFrame.lookAt(root.Position, Vector3.new(targetPart.Position.X, root.Position.Y, targetPart.Position.Z))
        hum.AutoRotate = false
        if cameraMode == "Lock-On" then camera.CFrame = CFrame.lookAt(camera.CFrame.Position, targetPart.Position) end
    else
        targetHighlight.Enabled = false
        isLocked, hum.AutoRotate = false, true
    end
end)
