local function getTarget()
    local closest = nil
    local shortestDistance = math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local root = p.Character.HumanoidRootPart
            local dist = (player.Character.HumanoidRootPart.Position - root.Position).Magnitude
            if dist <= maxDistance then
                local pos, onScreen = camera:WorldToViewportPoint(root.Position)
                if onScreen then
                    local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)).Magnitude
                    if mag < shortestDistance then
                        closest = root
                        shortestDistance = mag
                    end
                end
            end
        end
    end
    return closest
end

-- Smart Binder Function
BindButton.MouseButton1Click:Connect(function()
    isBinding = true
    BindButton.Text = "...WAITING FOR INPUT..."
    BindButton.BackgroundColor3 = Color3.fromRGB(70, 30, 30)
end)

UserInputService.InputBegan:Connect(function(input, processed)
    -- Handle Binding State
    if isBinding then
        if input.UserInputType == Enum.UserInputType.Keyboard or input.UserInputType == Enum.UserInputType.Gamepad1 or input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
            lockKey = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
            
            -- Display the key name nicely
            local keyName = tostring(lockKey):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
            BindButton.Text = "BIND: " .. keyName
            
            BindButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            isBinding = false
            return -- Stop here so we don't trigger a lock immediately
        end
    end

    if processed then return end

    -- Only check the specific key that was bound
    if input.KeyCode == lockKey or input.UserInputType == lockKey then
        isLocked = not isLocked
        
        if isLocked then
            targetPart = getTarget()
            if targetPart then
                StatusLabel.Text = "STATUS: LOCKED"
                StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
            else
                isLocked = false -- Auto-cancel if no one is around
            end
        else
            targetPart = nil
            StatusLabel.Text = "STATUS: IDLE"
            StatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
            if player.Character and player.Character:FindFirstChild("Humanoid") then
                player.Character.Humanoid.AutoRotate = true
            end
        end
    end
end)

ToggleBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
    ToggleBtn.Text = MainFrame.Visible and "HIDE MENU" or "SHOW MENU"
end)

-- Loop for Rotation and Ghosting
RunService.RenderStepped:Connect(function()
    -- Passive Ghosting (Always on)
    for _, other in pairs(Players:GetPlayers()) do
        if other ~= player and other.Character then
            for _, part in pairs(other.Character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end

    -- Face Lock
    if isLocked and targetPart and targetPart.Parent then
        local myChar = player.Character
        if myChar and myChar:FindFirstChild("HumanoidRootPart") then
            local myRoot = myChar.HumanoidRootPart
            local lookAtPos = Vector3.new(targetPart.Position.X, myRoot.Position.Y, targetPart.Position.Z)
            myRoot.CFrame = CFrame.lookAt(myRoot.Position, lookAtPos)
            if myChar:FindFirstChild("Humanoid") then myChar.Humanoid.AutoRotate = false end
        end
    else
        -- Safety: Re-enable AutoRotate if lock is lost/off
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            if player.Character.Humanoid.AutoRotate == false then
                player.Character.Humanoid.AutoRotate = true
            end
        end
    end
end)
